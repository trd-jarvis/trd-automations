    "positiveRules": {
      "requiredKeywords": ["weak site", "few reviews", "no faq"],
      "boostKeywords": ["missing schema", "slow site"],
      "blockedKeywords": ["dominant", "top rated"],
      "minimumScore": 35
    },
    "negativeRules": {
      "requiredKeywords": ["bad reviews", "complaints"],
      "boostKeywords": ["rating drop", "spam listing"],
      "blockedKeywords": ["5 stars", "recommended"],
      "minimumScore": 26
    }
